        <mxCell id="s5" value="音乐生成查询接口&#xa;读分布式状态&#xa;支持轮询 / 直接查询" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366" vertex="1" parent="skill-path">
          <mxGeometry x="340" y="200" width="280" height="60" as="geometry" />
        </mxCell>
        <mxCell id="s6" value="MV 一键生成接口 (全链路)&#xa;→ 脚本规划 + 主体图 + 视频 + 合成&#xa;一次提交, 全程自动化" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1" vertex="1" parent="skill-path">
          <mxGeometry x="20" y="310" width="600" height="80" as="geometry" />
        </mxCell>
        <mxCell id="s7" value="⚠ 强约束校验&#xa;MV 全流程按模型 + 分辨率自动计费,&#xa;提交时一次性校验积分, 不足直接拒绝" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450" vertex="1" parent="skill-path">
          <mxGeometry x="20" y="420" width="600" height="60" as="geometry" />
        </mxCell>
        <mxCell id="s8" value="能力描述文档&#xa;音乐生成 / MV 生成 / 上传&#xa;为开发者提供标准化接入指南" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656" vertex="1" parent="skill-path">
          <mxGeometry x="20" y="510" width="600" height="60" as="geometry" />
        </mxCell>
        <mxCell id="s9" value="面向开发者的可控维度&#xa;• 异步任务标识 / 状态轮询&#xa;• 一次性计费&#xa;• 与对话路径完全一致的音乐生成能力" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656" vertex="1" parent="skill-path">
          <mxGeometry x="20" y="600" width="600" height="100" as="geometry" />
        </mxCell>
        <mxCell id="s10" value="智能对话路径 vs 开放接口路径对比&#xa;• 对话路径: 实时流式, 支持多轮对话 / 修改, 按调用计费&#xa;• 接口路径: 标准 REST, 单次提交, 按任务计费&#xa;• 共性: 都使用相同的音乐生成与 MV 合成能力" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d4f1f4;strokeColor=#0b8082" vertex="1" parent="skill-path">
