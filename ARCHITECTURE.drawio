        <mxCell id="a6" value="歌曲生成&#xa;调用多模型负载均衡能力" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366" vertex="1" parent="agent-path">
          <mxGeometry x="340" y="210" width="280" height="60" as="geometry" />
        </mxCell>
        <mxCell id="a7" value="主模型成功?&#xa;→ 是: 采用主模型&#xa;→ 否: 自动切换备选模型" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656" vertex="1" parent="agent-path">
