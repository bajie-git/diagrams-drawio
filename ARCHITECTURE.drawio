  <diagram id="data-model" name="5. 核心数据模型关系图">
    <mxGraphModel dx="1800" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2339" pageHeight="1654" math="0" shadow="0">
      <root>
        <mxCell id="D0" />
        <mxCell id="D1" parent="D0" />
        <mxCell id="dt" value="核心数据模型关系图" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=20;fontStyle=1" vertex="1" parent="D1">
          <mxGeometry x="400" y="20" width="1200" height="40" as="geometry" />
        </mxCell>
        <mxCell id="d-script" value="MV 脚本 (AI 生成)&#xa;─────────────────────&#xa;内容概要: 文本&#xa;MV 总时长 (秒): 数值&#xa;分镜数: 整数&#xa;画幅: 横屏 / 竖屏&#xa;主体列表: 1..7 个主体&#xa;分镜表: N 个分镜" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;spacingLeft=10;fontSize=12" vertex="1" parent="D1">
          <mxGeometry x="80" y="100" width="320" height="160" as="geometry" />
        </mxCell>
        <mxCell id="d-subject" value="主体档案&#xa;(统一主体池, 1..7 个)&#xa;─────────────────────&#xa;主体 ID: 字符串 (全局唯一)&#xa;主体类型: 角色 / 物品 / 场景&#xa;主体描述: 文本&#xa;风格参考: 图片引用列表" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d4f1f4;strokeColor=#0b8082;align=left;spacingLeft=10;fontSize=12" vertex="1" parent="D1">
          <mxGeometry x="500" y="80" width="320" height="140" as="geometry" />
        </mxCell>
        <mxCell id="d-scene" value="分镜 (单镜头)&#xa;─────────────────────&#xa;分镜 ID: 字符串&#xa;开始时间: 数值 (0.001s 精度) ⏱&#xa;结束时间: 数值&#xa;时长: 数值&#xa;主体引用: 主体 ID 列表 👤&#xa;画面描述: 文本&#xa;是否口型同步: 是 / 否" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d4f1f4;strokeColor=#0b8082;align=left;spacingLeft=10;fontSize=12" vertex="1" parent="D1">
          <mxGeometry x="500" y="280" width="320" height="180" as="geometry" />
        </mxCell>
        <mxCell id="d-payload" value="统一任务载荷&#xa;(贯穿 MV 全流程的单一可信源)&#xa;─────────────────────&#xa;主体列表: 主体档案集合&#xa;分镜表: 分镜集合&#xa;画幅 / 分辨率&#xa;音频文件 ID&#xa;字幕时间线: 字幕行列表 ⏱" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=left;spacingLeft=10;fontSize=12;fontStyle=1" vertex="1" parent="D1">
          <mxGeometry x="900" y="100" width="360" height="160" as="geometry" />
        </mxCell>
        <mxCell id="d-payloadsubject" value="主体档案 + 锁定主体图&#xa;─────────────────────&#xa;继承: 主体档案所有字段&#xa;+ 锁定主体图 ID: 字符串  👤" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d4f1f4;strokeColor=#0b8082;align=left;spacingLeft=10;fontSize=12" vertex="1" parent="D1">
          <mxGeometry x="1340" y="100" width="320" height="100" as="geometry" />
        </mxCell>
        <mxCell id="d-payloadscene" value="分镜 + 绑定主体&#xa;─────────────────────&#xa;继承: 分镜所有字段&#xa;+ 分镜视频文件 ID&#xa;+ 口型同步文件 ID  ⏱&#xa;+ 主体引用解析表 👤&#xa;  (主体 ID → 实际文件 ID)&#xa;+ 智能缓存键 (5 小时)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d4f1f4;strokeColor=#0b8082;align=left;spacingLeft=10;fontSize=12" vertex="1" parent="D1">
          <mxGeometry x="1340" y="220" width="360" height="180" as="geometry" />
        </mxCell>
        <mxCell id="d-scenesubject" value="主体引用解析结果&#xa;(视频模型直接消费的格式)&#xa;─────────────────────&#xa;主体 ID: 字符串&#xa;主体图 ID: 字符串  👤" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d4f1f4;strokeColor=#0b8082;align=left;spacingLeft=10;fontSize=12" vertex="1" parent="D1">
          <mxGeometry x="1340" y="420" width="360" height="100" as="geometry" />
        </mxCell>
        <mxCell id="d-subtitle" value="字幕时间线&#xa;─────────────────────&#xa;音频总时长: 数值&#xa;字幕行: 列表 (开始 / 结束 / 文本) ⏱" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;align=left;spacingLeft=10;fontSize=12" vertex="1" parent="D1">
          <mxGeometry x="900" y="320" width="360" height="100" as="geometry" />
        </mxCell>
        <mxCell id="d-bt" value="音乐结构数据&#xa;(BPM / 节拍 / 段落)&#xa;─────────────────────&#xa;BPM: 每分钟节拍数&#xa;节拍点: 时间戳列表&#xa;段落: 段落列表&#xa;→ 注入到脚本生成的 AI 上下文" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;align=left;spacingLeft=10;fontSize=12" vertex="1" parent="D1">
          <mxGeometry x="80" y="320" width="320" height="140" as="geometry" />
        </mxCell>
        <mxCell id="p-lipsync" value="单分镜视频生成参数&#xa;─────────────────────&#xa;画面描述 / 时长&#xa;开始时间 / 结束时间 ⏱&#xa;主体 / 任务片段 ID&#xa;画幅 / 分辨率" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;spacingLeft=10;fontSize=12" vertex="1" parent="D1">
          <mxGeometry x="500" y="500" width="320" height="120" as="geometry" />
        </mxCell>
        <mxCell id="d-sse" value="实时推送消息格式 (类型联合)&#xa;─────────────────────&#xa;初始化 / 文字 / 思考过程&#xa;主体图 (含历史版本)  👤&#xa;分镜 (含历史版本)  👤⏱&#xa;分镜脚本 / 视频 / 音频 / 歌词&#xa;错误 / 完成" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=left;spacingLeft=10;fontSize=12;fontStyle=1" vertex="1" parent="D1">
