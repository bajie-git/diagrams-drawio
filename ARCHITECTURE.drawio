          <mxGeometry x="340" y="530" width="280" height="50" as="geometry" />
        </mxCell>
        <mxCell id="a15" value="面向用户的可控维度&#xa;• 歌曲标题 / 风格 / 歌词&#xa;• 是否纯音乐 / 男声 / 女声&#xa;• 词曲时间戳 (LRC) 供后续 MV 复用" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656" vertex="1" parent="agent-path">
          <mxGeometry x="20" y="620" width="600" height="80" as="geometry" />
        </mxCell>
        <mxCell id="a16" value="音乐创作剧本 (4 步标准作业流程)&#xa;• 第 1 步: 提取 风格 / 是否纯音乐 / 歌词 / 标题&#xa;• 第 2 步: 风格必填校验&#xa;• 第 3 步: 分支 A / B / C (纯音乐 / 用户歌词 / 自动歌词)&#xa;• 第 4 步: 调用歌曲生成" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00" vertex="1" parent="agent-path">
          <mxGeometry x="20" y="720" width="600" height="120" as="geometry" />
        </mxCell>
        <mxCell id="a17" value="强约束映射 (智能对话路径)&#xa;🎵 强音乐结构: 歌词创作 + 歌曲生成, 多维度可控 (性别 / 纯音乐 / 歌词)&#xa;⏱ 时间轴: 词曲时间戳 (LRC) 可被后续 MV 脚本生成直接引用&#xa;👤 主体一致性: 音乐支线无主体图, 不涉及" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d4f1f4;strokeColor=#0b8082" vertex="1" parent="agent-path">
          <mxGeometry x="20" y="860" width="600" height="100" as="geometry" />
        </mxCell>
        <mxCell id="skill-path" value="路径 B: 开放接口 (面向 ISV / 平台型客户)" style="swimlane;startSize=30;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;rounded=1;fontSize=14;fontStyle=1" vertex="1" parent="MU1">
          <mxGeometry x="860" y="80" width="740" height="1050" as="geometry" />
        </mxCell>
        <mxCell id="s1" value="第三方开发者&#xa;通过 APIKey 调用标准接口" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666" vertex="1" parent="skill-path">
          <mxGeometry x="20" y="40" width="280" height="50" as="geometry" />
        </mxCell>
        <mxCell id="s2" value="开放接口网关&#xa;APIKey 鉴权 + 流量控制&#xa;异步任务分发" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf" vertex="1" parent="skill-path">
          <mxGeometry x="340" y="40" width="280" height="50" as="geometry" />
        </mxCell>
        <mxCell id="s3" value="歌词生成接口&#xa;复用与对话路径相同的 AI 能力" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366" vertex="1" parent="skill-path">
          <mxGeometry x="20" y="120" width="280" height="50" as="geometry" />
        </mxCell>
        <mxCell id="s4" value="音乐生成提交接口&#xa;异步执行&#xa;写入分布式状态记录" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366" vertex="1" parent="skill-path">
