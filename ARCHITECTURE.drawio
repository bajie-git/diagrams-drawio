        <mxCell id="d-vioproject" value="最终作品 (入库)&#xa;─────────────────────&#xa;作品 ID: 内容指纹&#xa;文件 ID / 预览图 ID&#xa;作品名称 / 时长&#xa;歌词 / 元数据&#xa;作品类型: MV / 音乐 / ...&#xa;归属: 用户 / 会话 / 消息" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;spacingLeft=10;fontSize=12" vertex="1" parent="D1">
