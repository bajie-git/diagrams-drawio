        <mxCell id="a3" value="AI 创作助手&#xa;识别意图 → 音乐创作&#xa;加载音乐创作剧本" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1" vertex="1" parent="agent-path">
