        <mxCell id="m-music-1" value="歌词创作能力&#xa;将自然语言需求转化为标准化歌词&#xa;支持 [风格] / [标题] / [正文] 三段式" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450" vertex="1" parent="m-music">
          <mxGeometry x="20" y="60" width="460" height="60" as="geometry" />
        </mxCell>
        <mxCell id="m-music-2" value="歌曲生成能力&#xa;支持人声 / 纯音乐双模式&#xa;支持男声 / 女声 / 自定义风格标签" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450" vertex="1" parent="m-music">
          <mxGeometry x="20" y="140" width="460" height="60" as="geometry" />
        </mxCell>
        <mxCell id="m-music-3" value="多模型负载均衡&#xa;国际音乐生成模型 + 国内音乐生成模型&#xa;失败自动切换 / 末尾水印自动去除" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450" vertex="1" parent="m-music">
          <mxGeometry x="20" y="220" width="460" height="80" as="geometry" />
        </mxCell>
        <mxCell id="m-music-4" value="音乐结构智能分析&#xa;BPM / 节拍 / 段落自动识别&#xa;输出结构化节拍数据" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450" vertex="1" parent="m-music">
          <mxGeometry x="20" y="320" width="460" height="80" as="geometry" />
        </mxCell>
        <mxCell id="m-music-5" value="分镜节奏对齐&#xa;将节拍数据作为上下文输入给脚本生成&#xa;输出与音乐节奏对齐的分镜序列" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450" vertex="1" parent="m-music">
          <mxGeometry x="20" y="420" width="460" height="80" as="geometry" />
        </mxCell>
        <mxCell id="m-music-6" value="音频淡入淡出 / 合成&#xa;作品末尾 2 秒自然淡出&#xa;视频画面与音频轨道精准合并" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450" vertex="1" parent="m-music">
          <mxGeometry x="20" y="520" width="460" height="60" as="geometry" />
        </mxCell>
        <mxCell id="m-music-7" value="面向用户的可控维度&#xa;• 歌曲标题 / 风格 / 歌词&#xa;• 是否纯音乐 / 男声 / 女声&#xa;• 词曲时间戳 (LRC) 供后续 MV 复用" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656" vertex="1" parent="m-music">
          <mxGeometry x="20" y="600" width="460" height="100" as="geometry" />
        </mxCell>
        <mxCell id="m-music-8" value="触发时机: MV 全局规划环节中&#xa;节拍分析与脚本生成并行执行" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00" vertex="1" parent="m-music">
          <mxGeometry x="20" y="720" width="460" height="40" as="geometry" />
        </mxCell>
        <mxCell id="m-music-9" value="硬约束 (面向创作者的承诺)&#xa;• 同一主体在所有分镜中保持一致&#xa;• 单镜头时长不超过 10 秒&#xa;• 切镜时间精度 0.001 秒" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00" vertex="1" parent="m-music">
          <mxGeometry x="20" y="780" width="460" height="80" as="geometry" />
        </mxCell>
        <mxCell id="m-time" value="强时间轴约束 ⏱&#xa;Time-axis Constraint" style="swimlane;startSize=50;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;rounded=1;fontSize=16;fontStyle=1" vertex="1" parent="M1">
          <mxGeometry x="580" y="80" width="500" height="1050" as="geometry" />
        </mxCell>
        <mxCell id="m-time-1" value="脚本时间精度&#xa;每个分镜拥有精确的开始 / 结束 / 时长&#xa;毫秒级精度 (0.001s)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d79b00" vertex="1" parent="m-time">
          <mxGeometry x="20" y="60" width="460" height="60" as="geometry" />
        </mxCell>
        <mxCell id="m-time-2" value="字幕时间线对齐&#xa;字幕行开始 / 结束时间与分镜精准对齐&#xa;支持多语种字幕生成" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d79b00" vertex="1" parent="m-time">
          <mxGeometry x="20" y="140" width="460" height="60" as="geometry" />
        </mxCell>
        <mxCell id="m-time-3" value="唱歌识别能力&#xa;针对歌唱场景的语音识别&#xa;输出 LRC / SRT 级别时间戳" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d79b00" vertex="1" parent="m-time">
          <mxGeometry x="20" y="220" width="460" height="60" as="geometry" />
        </mxCell>
        <mxCell id="m-time-4" value="视频生成缓存&#xa;5 小时智能缓存, 避免重复生成&#xa;用户调整时按 (消息, 分镜) 维度复用" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d79b00" vertex="1" parent="m-time">
          <mxGeometry x="20" y="300" width="460" height="60" as="geometry" />
        </mxCell>
        <mxCell id="m-time-5" value="媒体精确裁剪与适配&#xa;将模型输出精裁到目标时长&#xa;720p / 1080p 横竖屏自适应" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d79b00" vertex="1" parent="m-time">
          <mxGeometry x="20" y="380" width="460" height="60" as="geometry" />
        </mxCell>
        <mxCell id="m-time-6" value="最终音视频合成&#xa;分镜拼接 + 音轨合并 + 末段淡出&#xa;保证总时长与音乐完全一致" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d79b00" vertex="1" parent="m-time">
          <mxGeometry x="20" y="460" width="460" height="60" as="geometry" />
        </mxCell>
        <mxCell id="m-time-7" value="口型同步能力&#xa;按分镜时长精确裁剪音频片段&#xa;嘴型与歌声逐帧对齐&#xa;失败时自动回退到原视频" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d79b00" vertex="1" parent="m-time">
          <mxGeometry x="20" y="540" width="460" height="80" as="geometry" />
        </mxCell>
        <mxCell id="m-time-8" value="字幕烧录&#xa;支持中英文字幕 + 自定义字体&#xa;按画幅自动调整字号" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d79b00" vertex="1" parent="m-time">
          <mxGeometry x="20" y="640" width="460" height="60" as="geometry" />
        </mxCell>
        <mxCell id="m-time-9" value="贯穿全程的时间数据&#xa;• MV 总时长 / 分镜数&#xa;• 单分镜 开始 / 结束 / 时长&#xa;• 字幕行 时间戳 / 文本" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656" vertex="1" parent="m-time">
          <mxGeometry x="20" y="720" width="460" height="100" as="geometry" />
        </mxCell>
        <mxCell id="m-time-10" value="触发时机&#xa;• MV 全局规划 (节拍 + 字幕识别并行) → 节奏锚点&#xa;• 作品合成 (合并 + 淡出 + 字幕烧录) → 最终时间轴" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00" vertex="1" parent="m-time">
          <mxGeometry x="20" y="840" width="460" height="80" as="geometry" />
        </mxCell>
        <mxCell id="m-subj" value="强主体一致性 👤&#xa;Subject Consistency" style="swimlane;startSize=50;html=1;fillColor=#d4f1f4;strokeColor=#0b8082;rounded=1;fontSize=16;fontStyle=1" vertex="1" parent="M1">
          <mxGeometry x="1100" y="80" width="500" height="1050" as="geometry" />
        </mxCell>
        <mxCell id="m-subj-1" value="统一主体档案&#xa;主体身份 / 类型 / 描述 / 风格参考&#xa;支持 1-7 个主体" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#0b8082" vertex="1" parent="m-subj">
          <mxGeometry x="20" y="60" width="460" height="60" as="geometry" />
        </mxCell>
        <mxCell id="m-subj-2" value="主体参考图生成&#xa;批量并行生成, 单任务最多 10 路并发&#xa;每次生成都形成独立版本, 可回溯切换" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#0b8082" vertex="1" parent="m-subj">
          <mxGeometry x="20" y="140" width="460" height="60" as="geometry" />
        </mxCell>
        <mxCell id="m-subj-3" value="参考图复用机制&#xa;同一主体在不同分镜中复用同一份参考图&#xa;保证跨镜头的视觉一致性" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#0b8082" vertex="1" parent="m-subj">
          <mxGeometry x="20" y="220" width="460" height="60" as="geometry" />
        </mxCell>
        <mxCell id="m-subj-4" value="主体池集中管理&#xa;每个作品维护一份唯一主体池&#xa;主体结果图 ID 被永久锁定" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#0b8082" vertex="1" parent="m-subj">
          <mxGeometry x="20" y="300" width="460" height="60" as="geometry" />
        </mxCell>
        <mxCell id="m-subj-5" value="分镜主体绑定&#xa;将分镜中引用主体的 ID 解析为&#xa;实际参考图 ID, 作为视频模型的统一输入" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#0b8082" vertex="1" parent="m-subj">
          <mxGeometry x="20" y="380" width="460" height="80" as="geometry" />
        </mxCell>
        <mxCell id="m-subj-6" value="主体 / 分镜在线编辑&#xa;支持新增 / 修改 / 删除三态&#xa;修改时自动检测, 主动触发对应分镜重生成" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#0b8082" vertex="1" parent="m-subj">
          <mxGeometry x="20" y="480" width="460" height="80" as="geometry" />
        </mxCell>
        <mxCell id="m-subj-7" value="作品库内二次编辑&#xa;在已发布作品上单独重做某个主体或某个分镜&#xa;保留原版本, 追加新版本供用户切换" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#0b8082" vertex="1" parent="m-subj">
          <mxGeometry x="20" y="580" width="460" height="60" as="geometry" />
        </mxCell>
        <mxCell id="m-subj-8" value="用户参考图理解&#xa;对用户上传的参考图自动理解&#xa;并提示与预期是否匹配, 避免误用" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#0b8082" vertex="1" parent="m-subj">
          <mxGeometry x="20" y="660" width="460" height="60" as="geometry" />
        </mxCell>
        <mxCell id="m-subj-9" value="贯穿全程的主体数据&#xa;• 主体档案 (身份 / 类型 / 描述 / 风格)&#xa;• 主体参考图 ID&#xa;• 分镜主体引用表 (主体 ID + 实际文件 ID)&#xa;• 主体图历史版本 (可切换)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656" vertex="1" parent="m-subj">
          <mxGeometry x="20" y="740" width="460" height="120" as="geometry" />
        </mxCell>
        <mxCell id="m-subj-10" value="触发时机&#xa;• 用户上传参考图 → 自动理解与匹配确认&#xa;• 主体图生成 → 主体池建立&#xa;• 分镜脚本更新 → 主体融入分镜&#xa;• 视频片段生成 → 主体参考喂入模型" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00" vertex="1" parent="m-subj">
          <mxGeometry x="20" y="880" width="460" height="80" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="mv-pipeline" name="3. MV 创作端到端流程图">
    <mxGraphModel dx="2000" dy="1400" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2339" pageHeight="1654" math="0" shadow="0">
      <root>
        <mxCell id="P0" />
        <mxCell id="P1" parent="P0" />
        <mxCell id="pt" value="MV 创作端到端流程 (8 步标准作业流程)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=20;fontStyle=1" vertex="1" parent="P1">
          <mxGeometry x="600" y="20" width="1200" height="40" as="geometry" />
        </mxCell>
        <mxCell id="p-user" value="创作者&#xa;用户 / 客户" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1" vertex="1" parent="P1">
          <mxGeometry x="60" y="80" width="120" height="60" as="geometry" />
        </mxCell>
        <mxCell id="p-vioservice" value="对话编排&#xa;实时流式会话&#xa;进度实时同步" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1" vertex="1" parent="P1">
          <mxGeometry x="240" y="80" width="200" height="60" as="geometry" />
        </mxCell>
        <mxCell id="p-assistant" value="AI 创作助手&#xa;意图理解 + 流程编排&#xa;加载 MV 创作剧本" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1" vertex="1" parent="P1">
          <mxGeometry x="500" y="80" width="220" height="60" as="geometry" />
        </mxCell>
        <mxCell id="p-mvtool" value="MV 创作工具集" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1" vertex="1" parent="P1">
          <mxGeometry x="780" y="80" width="200" height="60" as="geometry" />
        </mxCell>
        <mxCell id="p-project" value="作品生成与合成服务" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1" vertex="1" parent="P1">
          <mxGeometry x="1040" y="80" width="200" height="60" as="geometry" />
        </mxCell>
        <mxCell id="p-vlm" value="多模型适配层&#xa;图像 / 视频 / 音乐 /&#xa;口型 / 节拍分析" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1" vertex="1" parent="P1">
          <mxGeometry x="1300" y="80" width="220" height="60" as="geometry" />
        </mxCell>
        <mxCell id="p-infra" value="基础设施&#xa;媒体处理引擎 / 对象存储&#xa;数据库 / 缓存" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1" vertex="1" parent="P1">
          <mxGeometry x="1580" y="80" width="180" height="60" as="geometry" />
        </mxCell>
        <mxCell id="p-sse" value="实时推送通道&#xa;进度 / 主体 / 视频 / 文字" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6" vertex="1" parent="P1">
          <mxGeometry x="1820" y="80" width="240" height="60" as="geometry" />
        </mxCell>
        <mxCell id="p-step1" value="Step 1: 创意理解&#xa;提取音频 / 风格 / 画幅 / 歌词 / 参考图" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656" vertex="1" parent="P1">
          <mxGeometry x="60" y="180" width="360" height="50" as="geometry" />
        </mxCell>
        <mxCell id="p-step15" value="Step 1.5: 参考图智能理解&#xa;对用户上传图自动描述 + 匹配度评估&#xa;匹配度低时主动提醒用户确认" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d4f1f4;strokeColor=#0b8082" vertex="1" parent="P1">
          <mxGeometry x="60" y="250" width="360" height="60" as="geometry" />
        </mxCell>
        <mxCell id="p-step2" value="Step 2: 完整性校验 (核心红线)&#xa;缺少音频 → 终止生成, 引导上传 / 现创作" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450" vertex="1" parent="P1">
          <mxGeometry x="60" y="330" width="360" height="60" as="geometry" />
        </mxCell>
        <mxCell id="p-step3" value="Step 3: 任务初始化&#xa;为本次创作分配唯一任务编号&#xa;贯穿后续所有步骤" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00" vertex="1" parent="P1">
          <mxGeometry x="60" y="410" width="360" height="60" as="geometry" />
        </mxCell>
        <mxCell id="p-step4" value="Step 4: 全局规划 ★ 并行执行&#xa;├─ 音乐结构分析 (BPM / 节拍 / 段落) 🎵⏱&#xa;├─ 风格标准化&#xa;├─ 唱歌识别 (字幕时间线) ⏱&#xa;└─ 脚本生成 → 输出 分镜表 + 主体表 🎵⏱" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366" vertex="1" parent="P1">
          <mxGeometry x="60" y="490" width="360" height="120" as="geometry" />
        </mxCell>
        <mxCell id="p-step5" value="Step 5: 主体参考图生成 👤&#xa;├─ 多主体并发生成 (最多 10 路)&#xa;├─ 调用图像模型, 锁定参考图&#xa;├─ 历史版本可回溯, 切换&#xa;⚠ 等待用户确认主体图才能继续" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d4f1f4;strokeColor=#0b8082" vertex="1" parent="P1">
          <mxGeometry x="60" y="630" width="360" height="110" as="geometry" />
        </mxCell>
        <mxCell id="p-step6" value="Step 6: 分镜脚本确认 👤⏱&#xa;├─ 将主体融入分镜&#xa;├─ 推送到前端分镜展示&#xa;⚠ 等待用户确认分镜才能继续" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d4f1f4;strokeColor=#0b8082" vertex="1" parent="P1">
          <mxGeometry x="60" y="760" width="360" height="80" as="geometry" />
        </mxCell>
        <mxCell id="p-step7" value="Step 7: 视频片段生成 👤⏱&#xa;├─ 主体参考 ID 绑定, 传入视频模型&#xa;├─ 多分镜并发生成 (最多 10 路)&#xa;├─ 视频模型智能调度&#xa;├─ 媒体精裁到目标时长 + 分辨率适配&#xa;├─ 5 小时智能缓存避免重复生成&#xa;⚠ 等待用户确认视频片段才能继续" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d4f1f4;strokeColor=#0b8082" vertex="1" parent="P1">
          <mxGeometry x="60" y="860" width="360" height="160" as="geometry" />
        </mxCell>
        <mxCell id="p-step8" value="Step 8: 音视频合成 ⏱🎵&#xa;├─ 可选: 按分镜对口型 (嘴型同步) ⏱&#xa;├─ 分镜画面拼接&#xa;├─ 合并歌曲 + 末段 2 秒淡出 🎵&#xa;├─ 免费用户自动加水印 + 品牌片尾&#xa;└─ 可选: 字幕烧录到画面" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366" vertex="1" parent="P1">
          <mxGeometry x="60" y="1040" width="360" height="140" as="geometry" />
        </mxCell>
        <mxCell id="p-payload" value="统一任务载荷&#xa;贯穿整个 MV 创作全流程&#xa;├─ 主体池 (含锁定的主体图 ID) 👤&#xa;├─ 分镜表 (分镜 + 主体引用绑定) 👤⏱&#xa;├─ 音频文件 ID&#xa;├─ 字幕时间线 ⏱&#xa;├─ 画幅 / 分辨率&#xa;└─ 智能缓存键 (5 小时)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1" vertex="1" parent="P1">
          <mxGeometry x="480" y="180" width="380" height="180" as="geometry" />
        </mxCell>
        <mxCell id="p-script" value="MV 脚本 (AI 生成)&#xa;├─ 内容概要&#xa;├─ MV 总时长 (秒)&#xa;├─ 分镜数&#xa;├─ 主体列表 → 主体 ID 集合&#xa;└─ 分镜表 → 开始 / 结束 / 时长 ⏱" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656" vertex="1" parent="P1">
          <mxGeometry x="480" y="380" width="380" height="120" as="geometry" />
        </mxCell>
        <mxCell id="p-ssemag" value="实时推送消息类型&#xa;├─ 初始化 / 文字 / 思考过程&#xa;├─ 主体图 (含历史版本) 👤&#xa;├─ 分镜 (含历史版本) 👤⏱&#xa;├─ 分镜脚本 / 视频 / 音频 / 歌词&#xa;└─ 错误 / 完成" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6" vertex="1" parent="P1">
          <mxGeometry x="480" y="520" width="380" height="160" as="geometry" />
        </mxCell>
        <mxCell id="p-vioproj" value="最终作品&#xa;├─ 作品 ID (内容指纹)&#xa;├─ 预览图 ID&#xa;├─ 作品类型: MV&#xa;└─ 完整元数据 (用于资源库展示)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656" vertex="1" parent="P1">
          <mxGeometry x="480" y="700" width="380" height="100" as="geometry" />
        </mxCell>
        <mxCell id="p-lipsync" value="口型同步能力&#xa;├─ 按分镜时长精确裁剪对应音频片段&#xa;├─ 调用口型同步模型 (逐帧嘴型对齐)&#xa;└─ 失败时自动回退到原视频" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366" vertex="1" parent="P1">
          <mxGeometry x="900" y="180" width="380" height="100" as="geometry" />
        </mxCell>
        <mxCell id="p-analyzer" value="音乐结构分析&#xa;├─ 智能识别 BPM (每分钟节拍数)&#xa;├─ 智能识别每个节拍时间点&#xa;└─ 智能识别段落 (主歌 / 副歌 / 间奏)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366" vertex="1" parent="P1">
          <mxGeometry x="900" y="300" width="380" height="100" as="geometry" />
        </mxCell>
        <mxCell id="p-subtitle" value="字幕转写能力&#xa;├─ 专门针对唱歌场景&#xa;├─ 输出 LRC / SRT 级别时间戳&#xa;└─ 与分镜严格对齐" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366" vertex="1" parent="P1">
          <mxGeometry x="900" y="420" width="380" height="100" as="geometry" />
        </mxCell>
        <mxCell id="p-vlm2" value="视频模型智能调度&#xa;├─ 国际视频生成模型&#xa;├─ 国产视频生成模型 (快速版 / 高质量版)&#xa;└─ 按风格 / 分辨率 / 画幅智能选择&#xa;⚠ 注意: 主体图与视频生成需在同一账号, 保证一致性 👤" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656" vertex="1" parent="P1">
          <mxGeometry x="900" y="540" width="380" height="120" as="geometry" />
        </mxCell>
        <mxCell id="p-cv" value="媒体处理引擎 ⏱🎵&#xa;├─ 视频拼接 — 多分镜拼成完整 MV&#xa;├─ 音视频合成 — 合并歌曲 + 末段淡出&#xa;├─ 精确裁剪 — 视频 / 音频按毫秒级截取&#xa;├─ 分辨率适配 — 720p / 1080p 横竖屏&#xa;├─ 字幕烧录 — 字体 / 字号自适应画幅&#xa;├─ 水印叠加 / 品牌片尾拼接&#xa;└─ 元数据提取 / 缩略图生成" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666" vertex="1" parent="P1">
          <mxGeometry x="900" y="680" width="380" height="180" as="geometry" />
        </mxCell>
        <mxCell id="p-tos" value="对象存储&#xa;├─ 私有桶: 存储用户作品原始文件&#xa;└─ 公开桶: 存储分享预览图&#xa;按年月自动归档" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666" vertex="1" parent="P1">
          <mxGeometry x="1340" y="180" width="380" height="100" as="geometry" />
        </mxCell>
        <mxCell id="p-sse2" value="实时推送机制&#xa;├─ 助手产生消息 → 写入消息流 + 缓存队列&#xa;├─ 消费线程拉取并推送给用户终端&#xa;└─ 端到端秒级可达" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6" vertex="1" parent="P1">
          <mxGeometry x="1340" y="300" width="380" height="100" as="geometry" />
        </mxCell>
        <mxCell id="p-queue" value="分布式缓存&#xa;├─ 实时消息队列 (对话进度推送)&#xa;├─ 会话锁 (防止同一会话并发)&#xa;├─ 任务结果缓存 (5 小时避免重复生成)&#xa;├─ 分享链接缓存 (3 天有效)&#xa;└─ 口型同步临时文件 (24 小时)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666" vertex="1" parent="P1">
          <mxGeometry x="1340" y="420" width="380" height="160" as="geometry" />
        </mxCell>
        <mxCell id="p-mysql" value="关系数据库&#xa;├─ 会话表 (用户与 AI 的对话)&#xa;├─ 任务表 (每次 MV 创作的任务)&#xa;├─ 消息流表 (流式生成的中间片段)&#xa;└─ 作品表 (用户最终作品)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666" vertex="1" parent="P1">
          <mxGeometry x="1340" y="600" width="380" height="140" as="geometry" />
        </mxCell>
