        <mxCell id="a9" value="国内音乐生成模型&#xa;支持人声 / 纯乐器 / 自动去水印&#xa;(备选模型)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656" vertex="1" parent="agent-path">
